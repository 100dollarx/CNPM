<Window x:Class="ETMS.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ETMS — Dashboard"
        Width="1360" Height="820"
        MinWidth="1024" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border CornerRadius="16" Background="{StaticResource EtmsBg}" ClipToBounds="True">
        <Grid>
            <!-- Custom Title Bar -->
            <Border Height="44" VerticalAlignment="Top" Panel.ZIndex="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <SolidColorBrush Color="#111118" Opacity="0.9"/>
                </Border.Background>
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#06B6D4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⚡" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ETMS" FontSize="14" FontWeight="Bold" Foreground="#F1F5F9" VerticalAlignment="Center"/>
                        <TextBlock Text="  •  Esports Tournament Management" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" FontSize="12" Width="36" Height="30"
                                Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaxRestore" Content="□" FontSize="12" Width="36" Height="30"
                                Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BtnMaxRestore_Click"/>
                        <Button Content="✕" FontSize="12" Width="36" Height="30"
                                Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Layout -->
            <Grid Margin="0,44,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ SIDEBAR ═══ -->
                <Border Grid.Column="0" Background="{StaticResource EtmsSidebarBg}"
                        BorderBrush="{StaticResource EtmsBorder}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- User profile card -->
                        <Border Grid.Row="0" Margin="16,20,16,8" Padding="14" CornerRadius="12"
                                Background="#16161E">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="19">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="UserInitial" Text="A" FontSize="16" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock x:Name="UserFullName" Text="Administrator" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#F1F5F9"/>
                                    <TextBlock x:Name="UserRole" Text="Admin" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Navigation menu -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="12,8,12,0">
                            <StackPanel x:Name="NavMenu">
                                <!-- Section: TỔNG QUAN -->
                                <TextBlock Text="TỔNG QUAN" FontSize="10" FontWeight="Bold"
                                           Foreground="#475569" Margin="8,12,0,8" />

                                <Button x:Name="BtnOverview" Tag="overview" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonActiveStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Tổng quan" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <!-- Section: QUẢN LÝ GIẢI ĐẤU -->
                                <TextBlock Text="QUẢN LÝ GIẢI ĐẤU" FontSize="10" FontWeight="Bold"
                                           Foreground="#475569" Margin="8,20,0,8" />

                                <Button Tag="tournaments" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏆" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Giải đấu" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Button Tag="teams" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👥" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Đội tuyển" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Button Tag="bracket" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔀" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Bracket" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <!-- Section: THI ĐẤU -->
                                <TextBlock Text="THI ĐẤU" FontSize="10" FontWeight="Bold"
                                           Foreground="#475569" Margin="8,20,0,8" />

                                <Button Tag="schedule" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📅" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Lịch thi đấu" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Button Tag="checkin" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✅" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Check-in" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Button Tag="results" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Kết quả" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <!-- Section: HỆ THỐNG -->
                                <TextBlock Text="HỆ THỐNG" FontSize="10" FontWeight="Bold"
                                           Foreground="#475569" Margin="8,20,0,8" />

                                <Button Tag="leaderboard" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏅" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Bảng xếp hạng" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Button Tag="notifications" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔔" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Thông báo" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Button Tag="users" Click="NavButton_Click"
                                        Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👤" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Tài khoản" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Logout -->
                        <Border Grid.Row="2" Margin="12,0,12,16">
                            <Button Click="BtnLogout_Click" Cursor="Hand"
                                    Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪" FontSize="15" Margin="0,0,12,0"/>
                                    <TextBlock Text="Đăng xuất" FontSize="13" Foreground="#EF4444"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ MAIN CONTENT ═══ -->
                <Border Grid.Column="1" Padding="28,20">
                    <Grid x:Name="ContentArea">
                        <!-- Default: Overview content -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Page header -->
                                <Grid Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="Tổng quan" FontSize="26" FontWeight="Bold" Foreground="#F1F5F9"/>
                                        <TextBlock Text="Chào mừng trở lại! Đây là trạng thái hiện tại của hệ thống."
                                                   FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Stat cards row -->
                                <UniformGrid Columns="4" Margin="0,0,0,24">
                                    <!-- Card 1: Giải đấu -->
                                    <Border Margin="0,0,12,0" Padding="20" CornerRadius="14"
                                            Background="#16161E" BorderBrush="#1E293B" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#3B82F6" Opacity="0.15"/>
                                                    </Border.Background>
                                                    <TextBlock Text="🏆" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Giải đấu" FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="5" FontSize="28" FontWeight="Bold" Foreground="#F1F5F9" Margin="0,-2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Row="1" Height="1" Background="#1E293B" Margin="0,14,0,10"/>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Border Width="6" Height="6" CornerRadius="3" Background="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="2 đang diễn ra" FontSize="11" Foreground="#22C55E"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Card 2: Đội tuyển -->
                                    <Border Margin="6,0" Padding="20" CornerRadius="14"
                                            Background="#16161E" BorderBrush="#1E293B" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#8B5CF6" Opacity="0.15"/>
                                                    </Border.Background>
                                                    <TextBlock Text="👥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Đội tuyển" FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="48" FontSize="28" FontWeight="Bold" Foreground="#F1F5F9" Margin="0,-2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Row="1" Height="1" Background="#1E293B" Margin="0,14,0,10"/>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Border Width="6" Height="6" CornerRadius="3" Background="#F59E0B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="14 chờ duyệt" FontSize="11" Foreground="#F59E0B"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Card 3: Trận đấu -->
                                    <Border Margin="6,0" Padding="20" CornerRadius="14"
                                            Background="#16161E" BorderBrush="#1E293B" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#06B6D4" Opacity="0.15"/>
                                                    </Border.Background>
                                                    <TextBlock Text="⚔" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Trận đấu" FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="8" FontSize="28" FontWeight="Bold" Foreground="#F1F5F9" Margin="0,-2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Row="1" Height="1" Background="#1E293B" Margin="0,14,0,10"/>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Border Width="6" Height="6" CornerRadius="3" Background="#3B82F6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="3 hôm nay" FontSize="11" Foreground="#3B82F6"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Card 4: Thông báo -->
                                    <Border Margin="12,0,0,0" Padding="20" CornerRadius="14"
                                            Background="#16161E" BorderBrush="#1E293B" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#EF4444" Opacity="0.15"/>
                                                    </Border.Background>
                                                    <TextBlock Text="🔔" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Thông báo" FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="12" FontSize="28" FontWeight="Bold" Foreground="#F1F5F9" Margin="0,-2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Row="1" Height="1" Background="#1E293B" Margin="0,14,0,10"/>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Border Width="6" Height="6" CornerRadius="3" Background="#EF4444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="5 chưa đọc" FontSize="11" Foreground="#EF4444"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </UniformGrid>

                                <!-- Bottom section: Recent + Quick Actions -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.6*"/>
                                        <ColumnDefinition Width="0.4*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Recent Matches -->
                                    <Border Grid.Column="0" Margin="0,0,14,0" Padding="24" CornerRadius="14"
                                            Background="#16161E" BorderBrush="#1E293B" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Trận đấu gần đây" FontSize="16" FontWeight="SemiBold" Foreground="#F1F5F9" Margin="0,0,0,16"/>

                                            <!-- Match item 1 -->
                                            <Border Padding="12" Margin="0,0,0,8" CornerRadius="10" Background="#1E1E2E">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Team Alpha" FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="2 - 1" FontSize="14" FontWeight="Bold" Foreground="#3B82F6" Margin="12,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="Team Beta" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="#16A34A20">
                                                        <TextBlock Text="Hoàn thành" FontSize="10" Foreground="#22C55E"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Match item 2 -->
                                            <Border Padding="12" Margin="0,0,0,8" CornerRadius="10" Background="#1E1E2E">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Phoenix Rising" FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="vs" FontSize="13" Foreground="#64748B" Margin="12,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="Dark Storm" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="#3B82F620">
                                                        <TextBlock Text="Đang diễn ra" FontSize="10" Foreground="#60A5FA"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Match item 3 -->
                                            <Border Padding="12" Margin="0,0,0,0" CornerRadius="10" Background="#1E1E2E">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Cyber Wolves" FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="vs" FontSize="13" Foreground="#64748B" Margin="12,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="Nova Esports" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="#F59E0B20">
                                                        <TextBlock Text="Đã lên lịch" FontSize="10" Foreground="#FBBF24"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Quick Actions -->
                                    <Border Grid.Column="1" Padding="24" CornerRadius="14"
                                            Background="#16161E" BorderBrush="#1E293B" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Thao tác nhanh" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="#F1F5F9" Margin="0,0,0,16"/>

                                            <Button Margin="0,0,0,8" Padding="14,12" Cursor="Hand"
                                                    HorizontalContentAlignment="Left"
                                                    Background="#1E1E2E" BorderThickness="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="#1E1E2E" CornerRadius="10"
                                                                Padding="{TemplateBinding Padding}" Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="#252536"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="➕" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Tạo giải đấu mới" FontSize="13" Foreground="#F1F5F9"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Margin="0,0,0,8" Padding="14,12" Cursor="Hand"
                                                    HorizontalContentAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="#1E1E2E" CornerRadius="10"
                                                                Padding="{TemplateBinding Padding}" Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="#252536"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔀" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Generate Bracket" FontSize="13" Foreground="#F1F5F9"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Margin="0,0,0,8" Padding="14,12" Cursor="Hand"
                                                    HorizontalContentAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="#1E1E2E" CornerRadius="10"
                                                                Padding="{TemplateBinding Padding}" Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="#252536"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📋" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Xem Audit Log" FontSize="13" Foreground="#F1F5F9"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- System status -->
                                            <Border Height="1" Background="#1E293B" Margin="0,8,0,12"/>
                                            <TextBlock Text="TRẠNG THÁI HỆ THỐNG" FontSize="10" FontWeight="Bold"
                                                       Foreground="#475569" Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Border Width="8" Height="8" CornerRadius="4" Background="#22C55E" Margin="0,0,8,0"/>
                                                <TextBlock Text="SQL Server" FontSize="12" Foreground="#94A3B8" Width="100"/>
                                                <TextBlock Text="Online" FontSize="12" Foreground="#22C55E"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Border Width="8" Height="8" CornerRadius="4" Background="#22C55E" Margin="0,0,8,0"/>
                                                <TextBlock Text="Match Engine" FontSize="12" Foreground="#94A3B8" Width="100"/>
                                                <TextBlock Text="Running" FontSize="12" Foreground="#22C55E"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>

    <!-- ═══ Sidebar Button Styles ═══ -->
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1E1E2E"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
        </Style>
    </Window.Resources>
</Window>
