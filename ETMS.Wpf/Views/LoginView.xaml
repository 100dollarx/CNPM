<Window x:Class="ETMS.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ETMS — Đăng nhập"
        Width="1100" Height="680"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border CornerRadius="16" Background="{StaticResource EtmsBg}" ClipToBounds="True">
        <Grid>
            <!-- Title bar drag area -->
            <Border Height="40" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,12,0">
                    <Button Content="─" FontSize="12" Width="32" Height="28"
                            Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnMinimize_Click"/>
                    <Button Content="✕" FontSize="12" Width="32" Height="28"
                            Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,40,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.45*"/>
                    <ColumnDefinition Width="0.55*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ LEFT PANEL — Branding ═══ -->
                <Border Grid.Column="0" CornerRadius="0,0,0,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0F172A" Offset="0"/>
                            <GradientStop Color="#1E293B" Offset="0.5"/>
                            <GradientStop Color="#0F172A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <!-- Decorative circles -->
                        <Ellipse Width="300" Height="300" Opacity="0.05"
                                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-60,0,0">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="200" Height="200" Opacity="0.08"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-40,-40">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#06B6D4" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                            <!-- Logo icon -->
                            <Border Width="80" Height="80" CornerRadius="20" Margin="0,0,0,24"
                                    HorizontalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#06B6D4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B82F6" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                                <TextBlock Text="⚡" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="ETMS" FontSize="36" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Esports Tournament" FontSize="16" FontWeight="Light"
                                       Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock Text="Management System" FontSize="16" FontWeight="Light"
                                       Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>

                            <Border Height="1" Background="#1E293B" Margin="30,28,30,28"/>

                            <!-- Feature highlights -->
                            <StackPanel Margin="10,0">
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#22C55E" Margin="0,5,12,0"/>
                                    <TextBlock Text="Quản lý giải đấu Esports" Foreground="#CBD5E1" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#3B82F6" Margin="0,5,12,0"/>
                                    <TextBlock Text="Bracket tự động + Map Veto" Foreground="#CBD5E1" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#F59E0B" Margin="0,5,12,0"/>
                                    <TextBlock Text="Check-in + Xác thực kết quả" Foreground="#CBD5E1" FontSize="13"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ RIGHT PANEL — Login Form ═══ -->
                <Border Grid.Column="1" Background="{StaticResource EtmsBg}" CornerRadius="0,0,16,0">
                    <Grid VerticalAlignment="Center" Margin="60,0">
                        <StackPanel MaxWidth="380">
                            <TextBlock Text="Chào mừng trở lại" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource EtmsTextPrimary}"/>
                            <TextBlock Text="Đăng nhập vào hệ thống quản lý giải đấu"
                                       FontSize="14" Foreground="{StaticResource EtmsTextSecondary}" Margin="0,6,0,32"/>

                            <!-- Error message -->
                            <Border x:Name="ErrorBorder" Visibility="Collapsed"
                                    Background="#2D1215" CornerRadius="8"
                                    BorderBrush="#7F1D1D" BorderThickness="1" Padding="14,10" Margin="0,0,0,16">
                                <TextBlock x:Name="ErrorText" Foreground="#FCA5A5" FontSize="13" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Username -->
                            <TextBlock Text="TÀI KHOẢN" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource EtmsTextSecondary}" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtUsername" Style="{StaticResource EtmsTextBox}"
                                     Margin="0,0,0,20"/>

                            <!-- Password -->
                            <TextBlock Text="MẬT KHẨU" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource EtmsTextSecondary}" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="TxtPassword" Style="{StaticResource EtmsPasswordBox}"
                                         Margin="0,0,0,28"
                                         KeyDown="TxtPassword_KeyDown"/>

                            <!-- Login button -->
                            <Button x:Name="BtnLogin" Content="ĐĂNG NHẬP"
                                    Style="{StaticResource EtmsPrimaryButton}"
                                    Click="BtnLogin_Click"
                                    Height="48"/>

                            <!-- Footer -->
                            <TextBlock Text="© 2026 FIT TDTU — Kỹ thuật Phần mềm"
                                       FontSize="11" Foreground="#475569"
                                       HorizontalAlignment="Center" Margin="0,36,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
